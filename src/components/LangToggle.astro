---
// 한/영 슬라이딩 토글. 현재 보고 있는 언어 쪽으로 노브가 이동한다.
// [ ENG | KO ] — 한국어면 노브가 KO(오른쪽), 영어면 ENG(왼쪽).
// 노브 위치는 <html data-lang> 기반 CSS라 로드 즉시 올바른 위치(FOUC 없음).
---

<button id="lang-toggle" type="button" class="lang-switch" aria-label="언어 전환 / Toggle language">
  <span class="lang-switch__opt lang-switch__opt--en">ENG</span>
  <span class="lang-switch__opt lang-switch__opt--ko">KO</span>
  <span class="lang-switch__knob" aria-hidden="true"></span>
</button>

<style>
  .lang-switch {
    --sw-pad: 3px;
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    width: 5.5rem;
    height: 1.95rem;
    padding: var(--sw-pad);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    cursor: pointer;
    font: inherit;
    -webkit-tap-highlight-color: transparent;
  }
  .lang-switch__opt {
    position: relative;
    z-index: 1;
    text-align: center;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    line-height: 1;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
    user-select: none;
  }
  .lang-switch__knob {
    position: absolute;
    top: var(--sw-pad);
    left: var(--sw-pad);
    width: calc(50% - var(--sw-pad));
    height: calc(100% - var(--sw-pad) * 2);
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 1px 3px rgba(16, 24, 40, 0.25);
    transition: transform 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(100%); /* 기본(한국어): 노브를 KO(오른쪽)로 */
  }
  html[data-lang='en'] .lang-switch__knob {
    transform: translateX(0); /* 영어: 노브를 ENG(왼쪽)로 */
  }

  /* 활성 언어 라벨을 흰색으로(노브 위에 얹혀 보이도록) */
  .lang-switch__opt--ko {
    color: #fff;
  }
  html[data-lang='en'] .lang-switch__opt--ko {
    color: var(--color-text-muted);
  }
  html[data-lang='en'] .lang-switch__opt--en {
    color: #fff;
  }

  .lang-switch:hover {
    border-color: var(--color-accent);
  }
  .lang-switch:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }
</style>

<script>
  const toggle = document.getElementById('lang-toggle');

  // 현재 언어를 aria-label에 반영(스크린리더용)
  const sync = () => {
    if (!toggle) return;
    const lang = document.documentElement.getAttribute('data-lang') === 'en' ? 'en' : 'ko';
    toggle.setAttribute(
      'aria-label',
      lang === 'ko' ? '현재 한국어 — 영어로 전환' : 'Currently English — switch to Korean',
    );
  };

  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const current = root.getAttribute('data-lang') === 'en' ? 'en' : 'ko';
    const next = current === 'ko' ? 'en' : 'ko';
    root.setAttribute('data-lang', next);
    root.lang = next;
    try {
      localStorage.setItem('lang', next);
    } catch {
      /* localStorage 불가 시 무시 */
    }
    sync();
  });

  sync();
</script>
