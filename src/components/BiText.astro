---
// 한/영 텍스트를 두 개의 data-lang 블록으로 렌더(한쪽이 없으면 반대 언어로 폴백).
interface Props {
  ko?: string;
  en?: string;
  class?: string;
}
const { ko, en, class: cls } = Astro.props;
const koText = ko ?? en;
const enText = en ?? ko;
---
{koText && <span data-lang-block="ko" class={cls}>{koText}</span>}{
  enText && <span data-lang-block="en" class={cls}>{enText}</span>
}
